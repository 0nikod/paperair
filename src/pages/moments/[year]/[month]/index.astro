---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import MomentTimelineItem from "@components/MomentTimelineItem.astro";
import MomentsIndexLayout from "@layouts/MomentsIndexLayout.astro";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  const allMoments = await getCollection("moments", ({ data }) => {
    return import.meta.env.PROD ? data.test !== true : true;
  });

  const archiveMap = new Map<string, Set<string>>();

  allMoments.forEach((moment) => {
    const date = moment.data.pubDate;
    const year = date.getFullYear().toString();
    const month = (date.getMonth() + 1).toString().padStart(2, "0");

    if (!archiveMap.has(year)) {
      archiveMap.set(year, new Set());
    }
    archiveMap.get(year)?.add(month);
  });

  const paths: {
    params: { year: string; month: string };
    props: { allMoments: CollectionEntry<"moments">[] };
  }[] = [];
  archiveMap.forEach((months, year) => {
    months.forEach((month) => {
      paths.push({
        params: { year, month },
        props: { allMoments }, // Pass down, or just fetch again inside, passing down is usually faster
      });
    });
  });

  return paths;
}

interface Props {
  allMoments: CollectionEntry<"moments">[];
}

const { year, month } = Astro.params;
const { allMoments } = Astro.props as Props;

// Filter for this specific year/month
const sortedMoments = allMoments
  .filter((m: CollectionEntry<"moments">) => {
    const d = m.data.pubDate;
    const mYear = d.getFullYear().toString();
    const mMonth = (d.getMonth() + 1).toString().padStart(2, "0");
    return mYear === year && mMonth === month;
  })
  .sort(
    (a: CollectionEntry<"moments">, b: CollectionEntry<"moments">) =>
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

const title = `${year}年${month}月 - 动态归档`;
const description = `查看${year}年${month}月的动态记录。`;

// Pre-calculate showYear to avoid complex logic in JSX
const momentsWithYear = sortedMoments.map((moment, index) => {
  const momentYear = moment.data.pubDate.getFullYear().toString();
  const prevYear = sortedMoments[index - 1]?.data.pubDate
    .getFullYear()
    .toString();
  return {
    ...moment,
    showYear: momentYear !== prevYear,
  };
});
---

<MomentsIndexLayout
  title={title}
  description={description}
  allMoments={allMoments}
  activeYear={year}
  activeMonth={month}
  mobileDropdownText={`归档: ${year}-${month}`}
>
  <h1 slot="header" class="text-3xl font-bold mb-8 flex items-center gap-3">
    <Icon name="ri:time-line" class="text-primary w-8 h-8" />
    {year}年 {month}月的动态 ({sortedMoments.length})
  </h1>

  {
    sortedMoments.length === 0 ? (
      <div class="text-center py-20 text-base-content/50">
        <p>该月无动态</p>
      </div>
    ) : (
      <div class="flex flex-col gap-8 w-full">
        {momentsWithYear.map((moment, index) => (
          <MomentTimelineItem
            moment={moment}
            showYear={moment.showYear}
            isLast={index === momentsWithYear.length - 1}
          />
        ))}
      </div>
    )
  }
</MomentsIndexLayout>
