---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

// 尝试获取全量内容，按时间降序排列并截取前三篇
const allBlogPosts = await getCollection("blog")
  .then((posts) =>
    posts
      .filter((post) => !post.data.draft)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3),
  )
  .catch(() => []);

const allMoments = await getCollection("moments")
  .then((moments) =>
    moments
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3),
  )
  .catch(() => []);
---

<BaseLayout title="首页 - PaperAir" description="分享技术、生活与思考的个人空间">
  <div class="space-y-16 py-8">
    <!-- 英雄区域 -->
    <section class="relative w-screen max-w-[100vw] left-1/2 -translate-x-1/2 min-h-[460px] md:min-h-[560px] flex flex-col items-center justify-center overflow-hidden mb-12 isolate -mt-8 pt-8 group">
      
      <!-- 装饰性斜线组, 加入 mask-image 使得中间文字部分线条隐藏并实现柔和边缘扩散 -->
      <div class="absolute inset-0 w-full h-full pointer-events-none mix-blend-multiply opacity-50 transition-opacity duration-1500" style="mask-image: radial-gradient(ellipse 65% 55% at 50% 50%, transparent 35%, black 75%); -webkit-mask-image: radial-gradient(ellipse 65% 55% at 50% 50%, transparent 35%, black 75%);">
        
        <!-- 基础旋转容器，统一控制斜度并使其范围超过可视区域 -->
        <div class="absolute inset-[-150%] w-[400%] h-[400%] rotate-[-40deg] origin-center flex flex-col justify-center items-center gap-12 sm:gap-16 xl:gap-20 opacity-90 select-none pointer-events-none">
          
          <!-- 1. 顶部细灰线 -->
          <div class="w-[150%] h-[6px] bg-gray-400/80 blur-[0.5px]"></div>
          
          <!-- 2. 中灰色线 -->
          <div class="w-[150%] h-[6px] bg-[#6b7280] shadow-sm translate-x-32 drop-shadow-sm"></div>
          
          <!-- 3. 暗红线 -->
          <div class="w-[150%] h-[6px] bg-[#8a4242]/90 -translate-x-16 drop-shadow-sm"></div>
          
          <!-- 4. 黄线组 -->
          <div class="w-[150%] flex justify-between">
             <div class="w-[70%] h-[6px] bg-[#e6c800]/80 ml-[15%] shadow-[0_0_8px_rgba(230,200,0,0.6)]"></div>
          </div>
          
          <!-- 5. 粉紫线组 -->
          <div class="w-[150%] flex justify-around pl-[10%]">
             <div class="w-[55%] h-[6px] bg-[#d9a3ad]/90 border-r-[30vw] border-transparent translate-x-12 hidden md:block"></div>
             <div class="w-[50%] h-[6px] bg-[#d9a3ad]/70 translate-x-32 hidden md:block"></div>
          </div>
          
          <!-- 6. 银灰/浅紫线 -->
          <div class="w-[150%] h-[6px] bg-[#b8b0cf]/80 translate-x-44 shadow-[0_0_10px_rgba(184,176,207,0.5)]"></div>
          
          <!-- 7. 亮白/浅灰线 -->
          <div class="w-[150%] h-[6px] bg-[#c3c5ca] opacity-90 -translate-x-10 shadow-sm blur-[0.5px]"></div>
          
          <!-- 8. 底部细灰线 -->
          <div class="w-[150%] h-[6px] bg-[#888] opacity-60 translate-x-20"></div>

          <!-- 9. 额外填充线 -->
          <div class="w-[150%] h-[6px] bg-gray-300 opacity-40 translate-x-40 mt-12"></div>
        </div>
      </div>

      <!-- 内容区 -->
      <h1
        class="text-4xl md:text-6xl font-extrabold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
      >
        Welcome to PaperAir
        </h1>
      <div class="flex justify-center gap-4 pt-4">
        <a href="/blog" class="btn btn-primary rounded-full px-8">阅读文章</a>
        <a href="/about" class="btn btn-ghost rounded-full px-8">关于我</a>
      </div>
    </section>

    <!-- 最近文章 -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <span class="text-primary">#</span> 最近文章
        </h2>
        <a href="/blog" class="btn btn-ghost btn-sm">查看全部 &rarr;</a>
      </div>

      {
        allBlogPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allBlogPosts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="card bg-base-100 border border-base-200 hover:shadow-xl hover:border-primary/30 transition-all duration-300 group"
              >
                <div class="card-body">
                  <h3 class="card-title text-lg group-hover:text-primary transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="text-sm text-base-content/70 mt-2 line-clamp-3">
                      {post.data.description}
                    </p>
                  )}
                  <div class="flex items-center justify-between mt-6">
                    <time
                      datetime={post.data.pubDate.toISOString()}
                      class="text-xs text-base-content/50"
                    >
                      {post.data.pubDate.toLocaleDateString("zh-CN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="badge badge-secondary badge-outline badge-sm">
                        {post.data.tags[0]}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-16 bg-base-200/30 rounded-box border border-base-200 border-dashed">
            <p class="text-base-content/50">暂无可展示的文章，快去写一篇吧！</p>
          </div>
        )
      }
    </section>

    <!-- 最近动态 -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <span class="text-secondary">#</span> 最近动态
        </h2>
        <a href="/moments" class="btn btn-ghost btn-sm">查看全部 &rarr;</a>
      </div>

      {
        allMoments.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allMoments.map((moment) => (
              <div class="card bg-base-100 border border-base-200 hover:shadow-md transition-shadow">
                <div class="card-body p-6">
                  <!-- 由于动态正文是通过 body 提供，这里如果 body 较长可能需要截断。由于目前没有解析为 HTML，所以直接以纯文本展示部分或者依靠 prose。我们这里简单截断展示。 -->
                  <div class="text-sm text-base-content/80 line-clamp-4">
                    {moment.body}
                  </div>
                  <div class="mt-4 text-xs text-base-content/40 flex justify-end">
                    <time datetime={moment.data.pubDate.toISOString()}>
                      {moment.data.pubDate.toLocaleDateString("zh-CN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                        hour: "2-digit",
                        minute: "2-digit",
                      })}
                    </time>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-12 bg-base-200/30 rounded-box border border-base-200 border-dashed">
            <p class="text-base-content/50">最近没有发布任何动态哦。</p>
          </div>
        )
      }
    </section>
  </div>
</BaseLayout>
