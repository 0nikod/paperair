---
import { getCollection } from "astro:content";
import ArticleCard from "@components/ArticleCard.astro";
import HeroLines from "@components/HeroLines.astro";
import MomentCard from "@components/MomentCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

// 尝试获取全量内容，按时间降序排列并截取前三篇
const allBlogPosts = await getCollection("blog")
  .then((posts) =>
    posts
      .filter((post) => !post.data.draft)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3),
  )
  .catch(() => []);

const allMoments = await getCollection("moments")
  .then((moments) =>
    moments
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3),
  )
  .catch(() => []);
---

<BaseLayout
  title="首页 - PaperAir"
  description="分享技术、生活与思考的个人空间"
>
  <div class="space-y-16 py-8">
    <!-- 英雄区域 -->
    <section
      class="relative w-screen max-w-[100vw] left-1/2 -translate-x-1/2 min-h-[460px] md:min-h-[560px] flex flex-col items-center justify-center overflow-hidden mb-12 isolate -mt-8 pt-8 group"
    >
      <!-- 装饰性斜线组, 加入 mask-image 使得中间文字部分线条隐藏并实现柔和边缘扩散 -->
      <HeroLines />

      <!-- 内容区 -->
      <h1
        class="text-4xl md:text-6xl font-extrabold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
      >
        Welcome to PaperAir
      </h1>
      <div class="flex justify-center gap-4 pt-8">
        <a href="/blog" class="btn btn-primary rounded-full px-8">阅读文章</a>
        <a href="/about" class="btn btn-ghost rounded-full px-8">关于我</a>
      </div>
    </section>

    <!-- 最近文章 -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <span class="text-primary">#</span> 最近文章
        </h2>
        <a href="/blog" class="btn btn-ghost btn-sm">查看全部 &rarr;</a>
      </div>

      {
        allBlogPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allBlogPosts.map((post, index) => (
              <ArticleCard
                post={post}
                layout="card"
                class={
                  allBlogPosts.length === 3 && index === 2
                    ? "md:col-span-2 lg:col-span-1"
                    : ""
                }
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-16 bg-base-200/30 rounded-box border border-base-200 border-dashed">
            <p class="text-base-content/50">暂无可展示的文章，快去写一篇吧！</p>
          </div>
        )
      }
    </section>

    <!-- 最近动态 -->
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <span class="text-secondary">#</span> 最近动态
        </h2>
        <a href="/moments" class="btn btn-ghost btn-sm">查看全部 &rarr;</a>
      </div>

      {
        allMoments.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allMoments.map((moment, index) => (
              <MomentCard
                moment={moment}
                class={
                  allMoments.length === 3 && index === 2
                    ? "md:col-span-2 lg:col-span-1"
                    : ""
                }
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-12 bg-base-200/30 rounded-box border border-base-200 border-dashed">
            <p class="text-base-content/50">最近没有发布任何动态哦。</p>
          </div>
        )
      }
    </section>
  </div>
</BaseLayout>
