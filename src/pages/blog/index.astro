---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

// 获取全量博客文章，按时间降序排列
const allBlogPosts = await getCollection("blog")
  .then((posts) =>
    posts
      .filter((post) => !post.data.draft)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
  )
  .catch(() => []);
---

<BaseLayout title="博客 - PaperAir" description="所有博客文章列表">
  <div class="space-y-12 py-8">
    <header class="text-center space-y-4">
      <h1 class="text-4xl font-extrabold">博客</h1>
      <p class="text-base-content/70 max-w-2xl mx-auto">
        分享关于前端、后端、设计、以及生活中的一切感悟。欢迎在此驻足交流。
      </p>
    </header>

    <section>
      {
        allBlogPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allBlogPosts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="card bg-base-100 border border-base-200 hover:shadow-xl hover:border-primary/30 transition-all duration-300 group flex flex-col h-full"
              >
                <div class="card-body flex-1 flex flex-col">
                  <h2 class="card-title text-xl group-hover:text-primary transition-colors line-clamp-2">
                    {post.data.title}
                  </h2>
                  {post.data.description && (
                    <p class="text-sm text-base-content/70 mt-3 line-clamp-3">
                      {post.data.description}
                    </p>
                  )}
                  <div class="flex-1" />
                  <div class="flex items-center justify-between mt-6 pt-4 border-t border-base-200/50">
                    <time
                      datetime={post.data.pubDate.toISOString()}
                      class="text-xs text-base-content/50 font-medium"
                    >
                      {post.data.pubDate.toLocaleDateString("zh-CN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1 justify-end">
                        {post.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="badge badge-secondary badge-outline badge-sm">
                            {tag}
                          </span>
                        ))}
                        {post.data.tags.length > 2 && (
                          <span class="text-xs text-base-content/40 pl-1">
                            +{post.data.tags.length - 2}
                          </span>
                        )}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-20 bg-base-200/30 rounded-box border border-base-200 border-dashed">
            <h3 class="text-xl font-medium mb-2">暂无文章</h3>
            <p class="text-base-content/50">博主正在努力创作中，敬请期待！</p>
          </div>
        )
      }
    </section>
  </div>
</BaseLayout>
