---
import { Icon } from "astro-icon/components";
---

<label
  class="swap swap-rotate btn btn-ghost btn-circle btn-sm h-9 w-9"
  aria-label="切换主题"
>
  <!-- this hidden checkbox controls the state -->
  <input type="checkbox" class="theme-controller" value="paperair" />

  <!-- sun icon for light mode (checked state) -->
  <Icon name="ri:sun-line" class="swap-on h-5 w-5" />

  <!-- moon icon for dark mode (unchecked state) -->
  <Icon name="ri:moon-line" class="swap-off h-5 w-5" />
</label>

<script is:inline>
  // Script runs immediately to prevent flash of incorrect theme
  const getTheme = () => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
      return "paperair-dark";
    }
    return "paperair";
  };

  const theme = getTheme();
  const themeControllers = document.querySelectorAll(".theme-controller");

  // Initialize state
  if (theme === "paperair-dark") {
    document.documentElement.setAttribute("data-theme", "paperair-dark");
    themeControllers.forEach((el) => {
      if (el instanceof HTMLInputElement) el.checked = false; // paperair-dark is dark (unchecked moon)
    });
  } else {
    document.documentElement.setAttribute("data-theme", "paperair");
    themeControllers.forEach((el) => {
      if (el instanceof HTMLInputElement) el.checked = true; // paperair is light (checked sun)
    });
  }

  // Add event listeners to toggle
  themeControllers.forEach((el) => {
    el.addEventListener("change", (e) => {
      const isLight = e.target.checked;
      const newTheme = isLight ? "paperair" : "paperair-dark";

      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
    });
  });
</script>
