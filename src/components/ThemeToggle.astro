---
/**
 * 主题切换按钮组件
 * 提供一个带有动画效果（Swap）的按钮，用于在明亮（paperair）和暗黑（paperair-dark）主题间切换。
 * 脚本处理了主题的即时应用、持久化存储以及与系统主题偏好的同步。
 */
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  class="swap swap-rotate btn btn-ghost btn-circle btn-sm h-9 w-9"
  aria-label="切换主题"
>
  <!-- sun icon for light mode -->
  <Icon name="ri:sun-line" class="swap-on h-5 w-5" />

  <!-- moon icon for dark mode -->
  <Icon name="ri:moon-line" class="swap-off h-5 w-5" />
</button>

<script is:inline>
  // This runs synchronously and avoids button flashing on page load
  const toggleBtn = document.getElementById("theme-toggle");
  if (toggleBtn) {
    const currentTheme = document.documentElement.getAttribute("data-theme");
    if (currentTheme === "paperair") {
      toggleBtn.classList.add("swap-active");
    } else {
      toggleBtn.classList.remove("swap-active");
    }
  }
</script>

<script>
  // This script runs securely after the DOM has loaded
  const toggle = document.getElementById("theme-toggle");

  if (toggle) {
    // 2. Handle button clicks
    toggle.addEventListener("click", () => {
      // Toggle the swap animation class
      toggle.classList.toggle("swap-active");

      const isLight = toggle.classList.contains("swap-active");
      const newTheme = isLight ? "paperair" : "paperair-dark";

      // Apply the theme and save it
      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
    });
  }

  // 3. Optional: Sync changes if the OS preference changes while the user is browsing
  // Only override if the user hasn't actively set a preference in localStorage
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", (e) => {
      if (!localStorage.getItem("theme")) {
        const newTheme = e.matches ? "paperair-dark" : "paperair";
        document.documentElement.setAttribute("data-theme", newTheme);
        if (toggle) {
          if (newTheme === "paperair") {
            toggle.classList.add("swap-active");
          } else {
            toggle.classList.remove("swap-active");
          }
        }
      }
    });
</script>
