---
// src/components/HeroLines.astro
// 提供首页装饰性的斜线背景
---

<!-- 装饰性斜线组, 加入 mask-image 使得中间文字部分线条隐藏并实现柔和边缘扩散 -->
<div
  class="absolute inset-0 w-full h-full pointer-events-none mix-blend-multiply opacity-50 transition-opacity duration-1500"
  style="mask-image: radial-gradient(ellipse 65% 55% at 50% 50%, transparent 35%, black 75%); -webkit-mask-image: radial-gradient(ellipse 65% 55% at 50% 50%, transparent 35%, black 75%);"
>
  <!-- 基础旋转容器，统一控制斜度并使其范围超过可视区域 -->
  <div
    class="absolute inset-[-150%] w-[400%] h-[400%] rotate-[-40deg] origin-center flex flex-col justify-center items-center gap-12 sm:gap-16 xl:gap-20 opacity-90 select-none pointer-events-none"
  >
    <!-- 1. 顶部细灰线 -->
    <div class="w-[150%] h-[8px] bg-gray-400/80 blur-[0.5px]"></div>

    <!-- 2. 中灰色线 -->
    <div
      class="w-[150%] h-[14px] bg-[#6b7280] shadow-sm translate-x-32 drop-shadow-sm"
    >
    </div>

    <!-- 3. 暗红线 -->
    <div
      class="w-[150%] h-[12px] bg-[#8a4242]/90 -translate-x-16 drop-shadow-sm"
    >
    </div>

    <!-- 4. 黄线组 -->
    <div class="w-[150%] flex justify-between">
      <div
        class="w-[70%] h-[10px] bg-[#e6c800]/80 ml-[15%] shadow-[0_0_8px_rgba(230,200,0,0.6)]"
      >
      </div>
    </div>

    <!-- 5. 粉紫线组 -->
    <div class="w-[150%] flex justify-around pl-[10%]">
      <div
        class="w-[55%] h-[10px] bg-[#d9a3ad]/90 border-r-[30vw] border-transparent translate-x-12 hidden md:block"
      >
      </div>
      <div
        class="w-[50%] h-[10px] bg-[#d9a3ad]/70 translate-x-32 hidden md:block"
      >
      </div>
    </div>

    <!-- 6. 银灰/浅紫线 -->
    <div
      class="w-[150%] h-[10px] bg-[#b8b0cf]/80 translate-x-44 shadow-[0_0_10px_rgba(184,176,207,0.5)]"
    >
    </div>

    <!-- 7. 亮白/浅灰线 -->
    <div
      class="w-[150%] h-[16px] bg-[#c3c5ca] opacity-90 -translate-x-10 shadow-sm blur-[0.5px]"
    >
    </div>

    <!-- 8. 底部细灰线 -->
    <div class="w-[150%] h-[8px] bg-[#888] opacity-60 translate-x-20"></div>

    <!-- 9. 额外填充线 -->
    <div class="w-[150%] h-[8px] bg-gray-300 opacity-40 translate-x-40 mt-12">
    </div>
  </div>
</div>
