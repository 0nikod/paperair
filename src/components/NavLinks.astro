---
/**
 * 导航链接项渲染组件
 * 封装了导航菜单的渲染逻辑，支持桌面端（横格）和移动端（纵列）布局。
 * 自动根据当前路径（currentPath）判断并应用活动状态（Active）的高亮样式。
 */
import { NAV_LINKS } from "@consts";
import { resolvePath } from "@utils/path";

interface Props {
  /** 当前页面的路径 */
  currentPath: string;
  /** 是否使用移动端布局样式 */
  isMobile?: boolean;
}

const { currentPath, isMobile = false } = Astro.props;

const isActive = (href: string) => {
  const normalizedHref = resolvePath(href).replace(/\/$/, "");
  const normalizedPath = currentPath.replace(/\/$/, "");

  // If href is首页
  if (href === "/") {
    const base = import.meta.env.BASE_URL.replace(/\/$/, "");
    return normalizedPath === base || normalizedPath === "";
  }

  return (
    normalizedPath === normalizedHref ||
    normalizedPath.startsWith(`${normalizedHref}/`)
  );
};
---

{
  isMobile
    ? NAV_LINKS.map((link) => {
        const active = isActive(link.href);
        return (
          <li>
            <a
              href={resolvePath(link.href)}
              class={`text-[15px] font-medium py-2 ${
                active
                  ? "active bg-primary/10 text-primary"
                  : "text-base-content/80"
              }`}
              aria-current={active ? "page" : undefined}
            >
              {link.text}
            </a>
          </li>
        );
      })
    : NAV_LINKS.map((link) => {
        const active = isActive(link.href);
        return (
          <li class="h-16 flex items-center">
            <a
              href={resolvePath(link.href)}
              class={`relative text-[15px] font-medium transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary rounded-btn h-full flex items-center
                  ${
                    active
                      ? "text-primary"
                      : "text-base-content/70 hover:text-primary"
                  }`}
              aria-current={active ? "page" : undefined}
            >
              {link.text}
              {active && (
                <span class="absolute bottom-2 left-0 w-full h-[3px] bg-primary rounded-t-md shadow-[0_-2px_8px_rgba(var(--color-primary),0.5)]" />
              )}
            </a>
          </li>
        );
      })
}
