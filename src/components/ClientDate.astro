---
/**
 * 客户端日期渲染组件
 * 采用自定义元素 (Custom Element) 实现，确保日期在客户端按用户浏览器本地格式显示。
 * 解决了 SSR 与客户端活化（Hydration）时区不一致导致的文本闪烁或不匹配问题。
 */
import { TIMEZONE } from "@/settings/consts";

interface Props {
  /** 日期对象 */
  date: Date;
  /** 显示格式: 'date' (日期), 'datetime' (日期时间), 'time' (时间) */
  format?: "date" | "datetime" | "time";
  /** 自定义样式类 */
  class?: string;
  [key: string]: unknown;
}

const { date, format = "date", class: className, ...rest } = Astro.props;

// Server-side fallback: format using the configured TIMEZONE
const dateOptions: Intl.DateTimeFormatOptions = {
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: TIMEZONE,
};
const timeOptions: Intl.DateTimeFormatOptions = {
  hour: "2-digit",
  minute: "2-digit",
  timeZone: TIMEZONE,
};
const dateTimeOptions: Intl.DateTimeFormatOptions = {
  ...dateOptions,
  ...timeOptions,
};

const optionsMap = {
  date: dateOptions,
  time: timeOptions,
  datetime: dateTimeOptions,
};
const fallbackText = date.toLocaleString("zh-CN", optionsMap[format]);
---

<client-date data-format={format} class={className} {...rest}>
  <time datetime={date.toISOString()}>{fallbackText}</time>
</client-date>

<script>
  class ClientDateElement extends HTMLElement {
    connectedCallback() {
      const timeEl = this.querySelector("time");
      if (!timeEl) return;

      const iso = timeEl.getAttribute("datetime");
      if (!iso) return;

      const date = new Date(iso);
      const format = this.dataset.format || "date";

      const dateOpts: Intl.DateTimeFormatOptions = {
        year: "numeric",
        month: "short",
        day: "numeric",
      };
      const timeOpts: Intl.DateTimeFormatOptions = {
        hour: "2-digit",
        minute: "2-digit",
      };

      let opts: Intl.DateTimeFormatOptions;
      if (format === "time") {
        opts = timeOpts;
      } else if (format === "datetime") {
        opts = { ...dateOpts, ...timeOpts };
      } else {
        opts = dateOpts;
      }

      timeEl.textContent = date.toLocaleString("zh-CN", opts);
    }
  }

  customElements.define("client-date", ClientDateElement);
</script>
