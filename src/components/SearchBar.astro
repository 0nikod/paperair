---
import { Icon } from "astro-icon/components";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<site-search class={`form-control ${className}`}>
  <div class="relative">
    <label class="relative flex items-center">
      <span class="sr-only">搜索</span>
      <Icon
        name="ri:search-line"
        class="absolute left-3 w-4 h-4 text-base-content/40 pointer-events-none"
      />
      <input
        type="search"
        placeholder="搜索..."
        class="input input-sm h-9 bg-base-200/80 border-transparent hover:bg-base-200 rounded-full pl-9 w-32 sm:w-48 lg:w-56 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary focus:bg-base-100 focus:w-72 transition-all text-sm shadow-inner"
        data-search-input
        autocomplete="off"
      />
    </label>

    <!-- 搜索结果下拉面板 -->
    <div
      class="absolute right-0 top-full mt-2 w-md max-w-[calc(100vw-2rem)] bg-base-100 border border-base-300 rounded-box shadow-xl z-50 hidden"
      data-search-results
    >
      <!-- 头部栏 -->
      <div
        class="flex items-center justify-between px-3 py-2 border-b border-base-200"
        data-search-header
      >
        <span class="text-xs font-medium text-base-content/60" data-search-count
          >0 个结果</span
        >

        <!-- 筛选下拉菜单 (气泡/胶囊面板) -->
        <div class="dropdown dropdown-end">
          <button
            tabindex="0"
            class="btn btn-ghost btn-xs text-base-content/60 hover:bg-base-200"
          >
            <Icon name="ri:filter-3-line" class="w-3 h-3" />
            <span>筛选</span>
          </button>

          <div
            tabindex="0"
            class="dropdown-content z-60 menu p-3 shadow-xl bg-base-100 rounded-box w-64 mt-2 border border-base-200"
          >
            <!-- 时间筛选 (年月) -->
            <div class="mb-2">
              <h4
                class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-2 flex justify-between items-center"
              >
                <span>时间筛选</span>
                <button
                  type="button"
                  class="btn btn-ghost btn-xs text-base-content/50 hover:text-error px-1 hidden"
                  data-filter-time-clear
                  title="清除时间筛选"
                >
                  清除
                </button>
              </h4>
              <input
                type="month"
                class="input input-bordered input-xs w-full text-base-content/80"
                data-filter-time
                lang="zh-CN"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- 结果列表 -->
      <ul class="menu menu-sm p-2 max-h-128 overflow-y-auto" data-search-list>
      </ul>
    </div>
  </div>
</site-search>

<script>
  import { search } from "@utils/pagefinder";

  class SiteSearch extends HTMLElement {
    private input: HTMLInputElement;
    private panel: HTMLElement;
    private list: HTMLElement;
    private countSpan: HTMLElement;
    private timeInput: HTMLInputElement;
    private timeClearBtn: HTMLButtonElement;
    private debounceTimer: ReturnType<typeof setTimeout> | null = null;
    private currentTime: string = ""; // Format: "YYYY-MM" or ""

    constructor() {
      super();
      this.input = this.querySelector("[data-search-input]")!;
      this.panel = this.querySelector("[data-search-results]")!;
      this.list = this.querySelector("[data-search-list]")!;
      this.countSpan = this.querySelector("[data-search-count]")!;
      this.timeInput = this.querySelector("[data-filter-time]")!;
      this.timeClearBtn = this.querySelector("[data-filter-time-clear]")!;

      // 绑定方法，以便可以由 removeEventListener 卸载
      this.handleDocumentClick = this.handleDocumentClick.bind(this);
    }

    connectedCallback() {
      // 输入事件 — 带 300ms 防抖
      this.input.addEventListener("input", () => {
        if (this.debounceTimer) clearTimeout(this.debounceTimer);

        const query = this.input.value.trim();
        if (query.length > 1) {
          this.panel.classList.remove("hidden");
        } else {
          this.panel.classList.add("hidden");
        }

        this.debounceTimer = setTimeout(() => this.doSearch(), 300);
      });

      // 聚焦时展开面板
      this.input.addEventListener("focus", () => {
        if (this.input.value.trim().length > 1) {
          this.panel.classList.remove("hidden");
        }
      });

      // 点击外部关闭
      document.addEventListener("click", this.handleDocumentClick);

      // 原生月份选择器
      if (this.timeInput) {
        this.timeInput.addEventListener("change", () => {
          this.currentTime = this.timeInput.value; // ex: "2024-03"
          if (this.currentTime) {
            this.timeClearBtn.classList.remove("hidden");
          } else {
            this.timeClearBtn.classList.add("hidden");
          }
          this.doSearch();
        });
      }

      // 清除时间按钮
      if (this.timeClearBtn) {
        this.timeClearBtn.addEventListener("click", () => {
          this.timeInput.value = "";
          this.currentTime = "";
          this.timeClearBtn.classList.add("hidden");
          this.doSearch();
        });
      }
    }

    disconnectedCallback() {
      // 防止内存泄漏，移除挂载在全局 document 上的事件监听
      document.removeEventListener("click", this.handleDocumentClick);
    }

    private handleDocumentClick(e: MouseEvent) {
      if (!this.contains(e.target as Node)) {
        this.panel.classList.add("hidden");
      }
    }

    private async doSearch() {
      const query = this.input.value.trim();
      if (query.length < 2) {
        this.list.innerHTML = "";
        this.countSpan.textContent = "0 个结果";
        return;
      }

      // 解析 YYYY-MM
      let yearParam = "all";
      let monthParam = "all";
      if (this.currentTime) {
        yearParam = this.currentTime.substring(0, 4);
        monthParam = this.currentTime;
      }

      const results = await search(query, "all", yearParam, monthParam);

      this.list.innerHTML = "";
      this.countSpan.textContent = `${results.length} 个结果`;

      if (results.length === 0) {
        this.list.appendChild(this.createEmpty("未找到相关结果"));
        return;
      }

      for (const item of results) {
        const li = document.createElement("li");
        const a = document.createElement("a");
        a.href = item.url;
        a.className = "flex flex-col gap-1 items-start py-2";
        a.innerHTML = `
          <span class="flex items-center gap-2">
            <span class="badge badge-xs ${
              item.type === "blog" ? "badge-primary" : "badge-secondary"
            }">${item.type === "blog" ? "文章" : "动态"}</span>
            <span class="font-medium text-base-content text-sm line-clamp-1">${
              item.title
            }</span>
          </span>
          <span class="text-xs text-base-content/50 line-clamp-2 [&>mark]:bg-primary/20 [&>mark]:text-base-content">${
            item.excerpt
          }</span>
        `;
        li.appendChild(a);
        this.list.appendChild(li);
      }
    }

    private createEmpty(text: string): HTMLLIElement {
      const li = document.createElement("li");
      li.className = "px-3 py-6 text-center text-base-content/40 text-sm";
      li.textContent = text;
      return li;
    }
  }

  customElements.define("site-search", SiteSearch);
</script>
