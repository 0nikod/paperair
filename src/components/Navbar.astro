---
import NavLinks from "@components/NavLinks.astro";
import SearchBar from "@components/SearchBar.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { SITE_TITLE } from "@consts";
import { Icon } from "astro-icon/components";

const pathname = Astro.url.pathname;
const currentPath =
  pathname.length > 1 && pathname.endsWith("/")
    ? pathname.slice(0, -1)
    : pathname;
---

<header
  class="sticky top-0 z-50 w-full bg-base-100 shadow-sm transition-all duration-300"
>
  <nav
    class="navbar container mx-auto px-4 lg:px-8 max-w-7xl h-14 min-h-14"
    aria-label="主导航"
  >
    {/* Left: Logo & Title */}
    <div class="flex-1">
      <a
        href="/"
        class="flex items-center gap-2 hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary rounded-btn p-1"
        aria-label="返回首页"
      >
        <span class="text-lg font-bold hidden sm:inline-block">
          {SITE_TITLE}
        </span>
      </a>
    </div>

    {/* Right: Links & Search */}
    <div class="flex-none flex items-center gap-2 sm:gap-6">
      {/* Desktop Links */}
      <ul class="items-center gap-6 hidden md:flex">
        <NavLinks currentPath={currentPath} />
      </ul>

      {/* Search Bar */}
      <SearchBar class="hidden sm:block" />

      <ThemeToggle />

      {/* Mobile Menu Dropdown */}
      <div class="dropdown dropdown-end md:hidden">
        <div
          tabindex="0"
          role="button"
          class="btn btn-ghost btn-circle btn-sm h-9 w-9"
          aria-label="打开菜单"
        >
          <Icon name="ri:menu-line" class="h-5 w-5" />
        </div>
        <ul
          tabindex="0"
          class="menu menu-sm dropdown-content mt-4 z-1 p-3 shadow-lg bg-base-100 rounded-box w-52 border border-base-200 gap-1"
        >
          <NavLinks currentPath={currentPath} isMobile={true} />
        </ul>
      </div>
    </div>
  </nav>
</header>
