---
// src/components/Navbar.astro
---

<header
  class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-11/12 max-w-5xl rounded-full backdrop-blur lg:backdrop-blur-md bg-base-100/80 shadow-sm border border-base-200"
>
  <nav class="navbar px-4 min-h-14">
    <div class="navbar-start">
      <div class="dropdown">
        <div
          tabindex="0"
          role="button"
          class="btn btn-ghost lg:hidden"
          aria-label="Menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h8m-8 6h16"></path>
          </svg>
        </div>
        <ul
          tabindex="0"
          class="menu menu-sm dropdown-content mt-4 z-1 p-2 shadow-lg bg-base-100 rounded-box w-52 border border-base-200"
        >
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/moments">Moments</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
      <a href="/" class="btn btn-ghost text-xl font-bold tracking-tight"
        >PaperAir</a
      >
    </div>

    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 font-medium text-base gap-1">
        <li><a href="/" class="rounded-full px-4">Home</a></li>
        <li><a href="/blog" class="rounded-full px-4">Blog</a></li>
        <li><a href="/moments" class="rounded-full px-4">Moments</a></li>
        <li><a href="/about" class="rounded-full px-4">About</a></li>
      </ul>
    </div>

    <div class="navbar-end gap-2">
      <button
        class="btn btn-ghost btn-circle btn-sm md:btn-md"
        aria-label="Search"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </button>

      <!-- Theme toggle will be extracted to ThemeToggle.astro later -->
      <button
        class="btn btn-ghost btn-circle btn-sm md:btn-md"
        aria-label="Theme Toggle"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>
    </div>
  </nav>
</header>
