---
/**
 * 文章卡片组件
 * 用于在博客列表展示文章摘要、元数据（日期、字数、分类等）。
 * 支持两种布局模式：'card' (网格卡片) 和 'timeline' (时间轴风格)。
 */
import type { CollectionEntry } from "astro:content";
import ClientDate from "@components/ClientDate.astro";
import { Icon } from "astro-icon/components";

interface Props {
  /** 博客文章条目数据 */
  post: CollectionEntry<"blog">;
  /** 展示布局模式: 'card' (网格卡片) 或 'timeline' (时间轴风格) */
  layout?: "card" | "timeline";
  /** 自定义样式类 */
  class?: string;
}

const { post, layout = "card", class: className } = Astro.props;
const {
  title,
  description,
  pubDate,
  category,
  tags = [],
  heroImage,
} = post.data;

// 计算字数和阅读时间 (简单估算)
const wordCount = post.body ? post.body.length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 300));

const isCard = layout === "card";
---

{
  isCard ? (
    <a
      href={`/blog/${post.id}`}
      class:list={[
        "card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-all duration-300 group h-full",
        className,
      ]}
    >
      <div class="card-body p-6">
        <h3 class="card-title text-lg group-hover:text-primary transition-colors line-clamp-2">
          {title}
        </h3>
        {description && (
          <p class="text-sm text-base-content/70 mt-2 line-clamp-3 leading-relaxed">
            {description}
          </p>
        )}

        <div class="mt-auto pt-6">
          <div class="flex items-center text-xs text-base-content/50 gap-x-4 gap-y-2 flex-wrap">
            <span class="flex items-center gap-1">
              <Icon name="ri:calendar-line" class="w-3 h-3" />
              <ClientDate date={pubDate} format="date" />
            </span>
            <span class="flex items-center gap-1">
              <Icon name="ri:book-open-line" class="w-3 h-3" />
              {readingTime} 分钟
            </span>
            <span class="flex items-center gap-1">
              <Icon name="ri:article-line" class="w-3 h-3" />
              {wordCount} 字
            </span>
            {category && (
              <span class="flex items-center gap-1">
                <Icon name="ri:folder-line" class="w-3 h-3" />
                {category}
              </span>
            )}
            {tags && tags.length > 0 && (
              <span class="flex items-center gap-1">
                <Icon name="ri:price-tag-3-line" class="w-3 h-3" />
                {tags.join(" / ")}
              </span>
            )}
          </div>
        </div>
      </div>
    </a>
  ) : (
    <a
      href={`/blog/${post.id}`}
      data-blog-card
      data-category={category || ""}
      data-tags={tags.join(",")}
      class:list={[
        "card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-all duration-300 group overflow-hidden",
        className,
      ]}
    >
      <div class="p-5 md:p-6 flex gap-6 items-start w-full">
        <div class="flex-1 min-w-0">
          <h3 class="text-xl font-bold group-hover:text-primary transition-colors leading-snug mb-2">
            {title}
          </h3>
          <div class="text-sm text-base-content/50 font-medium mb-3">
            <ClientDate date={pubDate} format="date" />
          </div>
          {description && (
            <p class="text-sm text-base-content/70 line-clamp-2 leading-relaxed">
              {description}
            </p>
          )}
        </div>

        {heroImage && (
          <div class="hidden sm:block w-24 h-24 md:w-32 md:h-20 shrink-0">
            <img
              src={typeof heroImage === "string" ? heroImage : heroImage.src}
              alt={title}
              class="w-full h-full object-cover rounded shadow-xs group-hover:scale-105 transition-transform duration-500"
            />
          </div>
        )}
      </div>
    </a>
  )
}
