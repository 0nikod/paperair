---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  post: CollectionEntry<"blog">;
  layout?: "card" | "list";
  class?: string;
}

const { post, layout = "card", class: className } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isCard = layout === "card";
---

{
  isCard ? (
    <a
      href={`/blog/${post.id}`}
      class:list={[
        "card bg-base-100 border border-base-200 hover:shadow-md hover:border-primary/30 transition-all duration-300 group h-full",
        className,
      ]}
    >
      <div class="card-body p-6">
        <h3 class="card-title text-lg group-hover:text-primary transition-colors line-clamp-2">
          {title}
        </h3>
        {description && (
          <p class="text-sm text-base-content/70 mt-2 line-clamp-3 leading-relaxed">
            {description}
          </p>
        )}
        <div class="flex items-center justify-between mt-auto pt-6">
          <time
            datetime={pubDate.toISOString()}
            class="text-xs text-base-content/50"
          >
            {formattedDate}
          </time>
          {tags && tags.length > 0 && (
            <div class="badge badge-secondary badge-outline badge-sm">
              {tags[0]}
            </div>
          )}
        </div>
      </div>
    </a>
  ) : (
    <article
      class:list={[
        "card bg-base-100 border border-base-200 hover:shadow-md hover:border-primary/30 transition-all duration-300 group p-6",
        className,
      ]}
    >
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-x-4 gap-y-2 flex-wrap mb-2">
          <time
            datetime={pubDate.toISOString()}
            class="text-sm text-base-content/50 flex items-center gap-1"
          >
            <Icon name="ri:calendar-line" class="w-3.5 h-3.5" />
            {formattedDate}
          </time>
          {tags && tags.length > 0 && (
            <div class="flex gap-2">
              {tags.map((tag: string) => (
                <span class="badge badge-accent badge-outline badge-xs opacity-70">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>

        <h2 class="text-xl sm:text-2xl font-bold mb-2">
          <a
            href={`/blog/${post.id}`}
            class="hover:text-primary transition-colors block duration-300"
          >
            {title}
          </a>
        </h2>

        {description && (
          <p class="text-base-content/70 line-clamp-2 leading-relaxed text-sm sm:text-base">
            {description}
          </p>
        )}
      </div>
    </article>
  )
}
