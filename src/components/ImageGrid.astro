---
/**
 * 多图展示网格组件
 * 根据传入的图片数量自动计算并应用最优的网格布局（支持 1, 2, 3, 4 列）。
 * 点击图片可跳转至原图链接。
 */
import { Image } from "astro:assets";

interface Props {
  /** 包含图片元数据的数组 */
  images: ImageMetadata[];
  /** 自定义样式类 */
  class?: string;
}

const { images, class: className } = Astro.props;

// Determine layout based on number of images
let gridClass = "grid gap-2";
if (images.length === 1) {
  gridClass += " grid-cols-1";
} else if (images.length === 2 || images.length === 4) {
  gridClass += " grid-cols-2 w-fit";
} else {
  gridClass += " grid-cols-3";
}
---

{
  images.length > 0 && (
    <div class:list={[gridClass, className]}>
      {images.map((image, index) => (
        <a
          href={image.src}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full overflow-hidden rounded-box bg-base-200 border border-base-content/10"
        >
          <Image
            src={image}
            alt={`Image ${index + 1}`}
            width={400}
            height={400}
            class={`w-full h-full object-cover transition-transform duration-300 hover:scale-105 ${
              images.length === 1 ? "max-h-96" : "aspect-square"
            }`}
          />
        </a>
      ))}
    </div>
  )
}
