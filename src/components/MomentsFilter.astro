---
/**
 * 动态归档筛选侧边栏组件
 * 按年份和月份对所有动态进行归档聚合。
 * 提供导航链接，点击可跳转至对应的年月动态列表页。
 */
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  /** 所有动态集合，用于统计归档数量 */
  moments: CollectionEntry<"moments">[];
  /** 当前选中的年份（用于展示状态和自动展开功能） */
  activeYear?: string | undefined;
  /** 当前选中的月份 */
  activeMonth?: string | undefined;
  /** 自定义样式类 */
  class?: string | undefined;
}

const { moments, activeYear, activeMonth, class: className } = Astro.props;

// Group moments by year and month
const archiveMap = new Map<string, Set<string>>();

moments.forEach((moment) => {
  const date = moment.data.pubDate;
  const year = date.getFullYear().toString();
  // Ensure month is 2 digits
  const month = (date.getMonth() + 1).toString().padStart(2, "0");

  if (!archiveMap.has(year)) {
    archiveMap.set(year, new Set());
  }
  archiveMap.get(year)?.add(month);
});

// Convert to sorted array
const archives = Array.from(archiveMap.entries())
  .map(([year, monthsSet]) => ({
    year,
    months: Array.from(monthsSet).sort((a, b) => b.localeCompare(a)), // Descending months
  }))
  .sort((a, b) => b.year.localeCompare(a.year)); // Descending years
---

<div class:list={["w-full", className]}>
  <h2 class="text-lg font-bold mb-4 px-4 flex items-center gap-2">
    <Icon name="ri:calendar-2-line" class="w-5 h-5" /> 归档
  </h2>
  <ul class="menu bg-base-200/50 w-full rounded-box">
    <li>
      <a href="/moments" class={!activeYear && !activeMonth ? "active" : ""}>
        全部动态
      </a>
    </li>
    {
      archives.map((archive) => (
        <li>
          <details
            open={activeYear === archive.year || !activeYear}
            class="group"
          >
            <summary class="p-0 hover:bg-transparent active:bg-transparent active:text-current [&::after]:hidden flex">
              <a
                href={`/moments/${archive.year}/`}
                class:list={[
                  "flex-1 px-4 py-2 rounded-l-btn rounded-r-none hover:bg-base-content/10",
                  activeYear === archive.year && !activeMonth
                    ? "active font-bold"
                    : "font-medium",
                ]}
                onclick="event.stopPropagation();"
              >
                {archive.year} 年
              </a>
              <span class="px-3 py-2 rounded-r-btn rounded-l-none flex items-center justify-center hover:bg-base-content/10 cursor-pointer">
                <Icon
                  name="ri:arrow-down-s-line"
                  class="w-5 h-5 transition-transform duration-200 group-open:-rotate-180"
                />
              </span>
            </summary>
            <ul>
              {archive.months.map((month) => {
                const isActive =
                  activeYear === archive.year && activeMonth === month;
                return (
                  <li>
                    <a
                      href={`/moments/${archive.year}/${month}/`}
                      class={isActive ? "active font-bold" : ""}
                    >
                      {month} 月
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        </li>
      ))
    }
  </ul>
</div>
