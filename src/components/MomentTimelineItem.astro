---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import ImageGrid from "./ImageGrid.astro";

interface Props {
  moment: CollectionEntry<"moments">;
  class?: string;
  showYear?: boolean; // Whether to emphasize the year in the date display
}

const { moment, class: className, showYear = false } = Astro.props;
const { Content } = await render(moment);

const date = moment.data.pubDate;
const year = date.getFullYear().toString();
const month = (date.getMonth() + 1).toString().padStart(2, "0");
const day = date.getDate().toString().padStart(2, "0");
const time = date.toLocaleTimeString("zh-CN", {
  hour: "2-digit",
  minute: "2-digit",
});

// A unique URL for this moment
const momentUrl = `/moments/${year}/${month}/${day}/${moment.id.replace(
  /\.[^/.]+$/,
  "",
)}/`;
---

<div class:list={["flex gap-4 w-full relative group", className]}>
  {/* Timeline vertical line */}
  <div
    class="absolute left-10 md:left-16 top-10 -bottom-10 w-px bg-base-300 group-last:hidden"
  >
  </div>

  {/* Date & Time Column */}
  {
    /* On mobile, date can be above or small. Let's keep it left for desktop, and above for mobile?
      Or just left always, with a responsive width. */
  }
  <div class="w-20 md:w-32 shrink-0 flex flex-col items-end pt-1">
    <div class="text-sm md:text-base font-bold text-base-content/80">
      {showYear ? `${year}-${month}-${day}` : `${month}-${day}`}
    </div>
    <div class="text-xs text-base-content/50">{time}</div>
  </div>

  {/* Timeline Dot */}
  <div
    class="relative z-10 w-4 h-4 mt-2 rounded-full border-2 border-primary bg-base-100 shrink-0 flex items-center justify-center"
  >
    <div
      class="w-1.5 h-1.5 bg-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
    >
    </div>
  </div>

  {/* Card Content */}
  <moment-expandable class="grow pb-10">
    <div
      class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow"
    >
      <div
        class="card-body p-4 md:p-6 overflow-hidden relative"
        data-content-container
      >
        {/* Content proper */}
        <div class="prose prose-sm max-w-none mb-4 prose-a:text-primary">
          <Content />
        </div>

        {/* Images Grid */}
        {
          moment.data.images && moment.data.images.length > 0 && (
            <ImageGrid images={moment.data.images} class="mt-2" />
          )
        }

        {/* Gradient Cover for truncation */}
        <div
          data-gradient-cover
          class="absolute bottom-0 left-0 right-0 h-24 bg-linear-to-t from-base-100 to-transparent hidden"
        >
          {
            /* The button is handled below, but gradient needs to sit at the bottom */
          }
        </div>
      </div>

      <div
        class="px-6 pb-4 pt-1 flex justify-between items-center border-t border-base-200/50 mt-2"
      >
        <a
          href={momentUrl}
          class="text-xs text-base-content/50 hover:text-primary transition-colors flex items-center gap-1"
        >
          <Icon name="ri:link" class="w-3.5 h-3.5" />
          单页
        </a>
        <button
          data-expand-btn
          class="btn btn-ghost btn-xs text-primary hidden"
        >
          展开全文 <Icon
            name="ri:arrow-down-s-line"
            class="inline w-3.5 h-3.5"
          />
        </button>
      </div>
    </div>
  </moment-expandable>
</div>

<script>
  class MomentExpandable extends HTMLElement {
    constructor() {
      super();
      const container = this.querySelector(
        "[data-content-container]"
      ) as HTMLElement;
      const expandBtn = this.querySelector(
        "[data-expand-btn]"
      ) as HTMLButtonElement;
      const gradientCover = this.querySelector(
        "[data-gradient-cover]"
      ) as HTMLElement;

      const MAX_HEIGHT = 300; // pixels
      let isExpanded = false;

      // Check height after images or fonts load
      const checkHeight = () => {
        // Reset max-height momentarily to measure true height
        container.style.maxHeight = "none";
        const trueHeight = container.scrollHeight;

        if (trueHeight > MAX_HEIGHT * 1.2) {
          // Add 20% slack so we don't truncate just for a few pixels
          if (!isExpanded) {
            container.style.maxHeight = `${MAX_HEIGHT}px`;
            expandBtn.classList.remove("hidden");
            gradientCover.classList.remove("hidden");
          }
        } else {
          container.style.maxHeight = "none";
          expandBtn.classList.add("hidden");
          gradientCover.classList.add("hidden");
        }
      };

      // Initial check
      checkHeight();

      // Listen for window resize
      window.addEventListener("resize", checkHeight);

      // Handle button click
      if (expandBtn) {
        expandBtn.addEventListener("click", () => {
          isExpanded = !isExpanded;
          if (isExpanded) {
            container.style.maxHeight = "none";
            gradientCover.classList.add("hidden");
            expandBtn.innerHTML = `收起 <span class="i-ri-arrow-up-s-line w-4 h-4"></span>`;
          } else {
            container.style.maxHeight = `${MAX_HEIGHT}px`;
            gradientCover.classList.remove("hidden");
            expandBtn.innerHTML = `展开全文 <span class="i-ri-arrow-down-s-line w-4 h-4"></span>`;

            // Scroll back up if needed, so user doesn't lose context
            const rect = this.getBoundingClientRect();
            if (rect.top < 0) {
              window.scrollBy({
                top: rect.top - 100, // 100px offset for header
                behavior: "smooth",
              });
            }
          }
        });
      }

      // Also observe images loading within this component to re-check height
      const images = this.querySelectorAll("img");
      images.forEach((img) => {
        if (!img.complete) {
          img.addEventListener("load", checkHeight);
        }
      });
    }
  }

  customElements.define("moment-expandable", MomentExpandable);
</script>
