---
/**
 * 动态时间轴单项组件
 * 在时间轴中展示完整的动态内容，包括文字（Markdown 渲染）和图片。
 * 支持内容超长折叠、展开功能，以及生成动态的单页链接。
 */
import type { CollectionEntry } from "astro:content";
import ClientDate from "@components/ClientDate.astro";
import MomentCard from "@components/MomentCard.astro";

interface Props {
  /** 动态条目数据 */
  moment: CollectionEntry<"moments">;
  /** 自定义样式类 */
  class?: string;
  /** 是否在日期显示中强调年份 */
  showYear?: boolean;
  /** 是否为时间轴的最后一项（用于控制垂直延伸线的显示） */
  isLast?: boolean;
}

const {
  moment,
  class: className,
  showYear = false,
  isLast = false,
} = Astro.props;

const date = moment.data.pubDate;
const year = date.getFullYear().toString();
const month = (date.getMonth() + 1).toString().padStart(2, "0");
const day = date.getDate().toString().padStart(2, "0");
---

<article class:list={["flex gap-4 w-full relative group", className]}>
  {/* Timeline vertical line */}
  {
    !isLast && (
      <div
        class="absolute left-10 md:left-16 top-10 -bottom-10 w-px bg-base-300"
        aria-hidden="true"
      />
    )
  }

  {/* Date & Time Column */}
  <div class="w-20 md:w-32 shrink-0 flex flex-col items-end pt-1">
    <div class="flex flex-col items-end">
      <div class="text-sm md:text-base font-bold text-base-content/80">
        {showYear ? `${year}-${month}-${day}` : `${month}-${day}`}
      </div>
      <ClientDate
        date={date}
        format="time"
        class="text-xs text-base-content/50"
      />
    </div>
  </div>

  {/* Timeline Dot */}
  <div
    class="relative z-10 w-4 h-4 mt-2 rounded-full border-2 border-primary bg-base-100 shrink-0 flex items-center justify-center group-hover:bg-primary/20 transition-colors duration-300"
    aria-hidden="true"
  >
  </div>
  <span data-pagefind-filter={`year:${year}`} class="hidden"></span>
  <span data-pagefind-filter={`month:${year}-${month}`} class="hidden"></span>

  {/* Card Content (Extracted to MomentCard) */}
  <div class="grow pb-10">
    <MomentCard moment={moment} />
  </div>
</article>
