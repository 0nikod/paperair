---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

import type { MarkdownHeading } from "astro";

interface Props {
  post: CollectionEntry<"blog">;
  headings: MarkdownHeading[];
  readingTime: number;
}

const { post, headings, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage } = post.data;

const formattedPubDate = pubDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// 处理 TOC 层级关系
const toc = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .reduce(
    (acc, heading) => {
      if (heading.depth === 2) {
        acc.push({ ...heading, subHeadings: [] });
      } else if (heading.depth === 3 && acc.length > 0) {
        const lastH2 = acc[acc.length - 1];
        if (lastH2) {
          lastH2.subHeadings.push(heading);
        }
      }
      return acc;
    },
    [] as (MarkdownHeading & { subHeadings: MarkdownHeading[] })[],
  );
---

<BaseLayout title={`${title} | PaperAir`} description={description}>
  <div class="blog-layout py-8 lg:py-12">
    <!-- 两栏布局：文章 + TOC -->
    <div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-8">
      <!-- 文章卡片 -->
      <article
        class="card bg-base-100 shadow-sm border border-base-300 min-w-0"
      >
        <!-- 封面图（卡片顶部，无内边距） -->
        {
          heroImage && (
            <figure>
              <img
                src={heroImage}
                alt={title}
                class="w-full object-cover max-h-80"
              />
            </figure>
          )
        }

        <!-- 卡片内容区 -->
        <div class="card-body">
          <!-- 文章头部信息 -->
          <header class="mb-6">
            <h1
              class="text-3xl sm:text-4xl font-extrabold text-base-content leading-tight"
            >
              {title}
            </h1>
            {
              description && (
                <p class="mt-3 text-lg text-base-content/60">{description}</p>
              )
            }
            <div
              class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-content/50"
            >
              <time datetime={pubDate.toISOString()}>
                {formattedPubDate}
              </time>
              {
                formattedUpdatedDate && (
                  <span>(更新于 {formattedUpdatedDate})</span>
                )
              }
              <span class="reading-time">约 {readingTime} 分钟阅读</span>
            </div>
            <div class="divider mt-6 mb-0"></div>
          </header>

          <!-- Markdown 渲染区域 -->
          <div class="prose prose-base max-w-none" id="article-content">
            <slot />
          </div>
        </div>
      </article>

      <!-- 右侧 TOC 卡片 -->
      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <nav
            class="card bg-base-100 shadow-sm border border-base-300 p-5"
            id="toc-nav"
          >
            <header class="flex items-center gap-2 mb-4 text-base-content/80">
              <span class="text-xl font-bold">#</span>
              <span class="text-sm font-semibold">目录</span>
            </header>
            <ol class="toc-list text-sm space-y-1" id="toc-list">
              {
                toc.length > 0 ? (
                  toc.map((h2) => (
                    <li>
                      <a href={`#${h2.slug}`}>{h2.text}</a>
                      {h2.subHeadings.length > 0 && (
                        <ol>
                          {h2.subHeadings.map((h3) => (
                            <li>
                              <a href={`#${h3.slug}`}>{h3.text}</a>
                            </li>
                          ))}
                        </ol>
                      )}
                    </li>
                  ))
                ) : (
                  <li class="text-base-content/50 italic">暂无目录</li>
                )
              }
            </ol>
          </nav>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .toc-list {
    list-style: none;
    padding: 0;
    counter-reset: toc-h2;
  }

  .toc-list :global(li) {
    counter-increment: toc-h2;
    counter-reset: toc-h3;
  }

  .toc-list :global(li > a) {
    display: block;
    padding: 0.25rem 0;
    color: oklch(50% 0.01 260);
    text-decoration: none;
    transition: color 0.15s;
  }

  .toc-list :global(li > a::before) {
    content: counters(toc-h2, ".") ". ";
  }

  .toc-list :global(li > a:hover) {
    color: oklch(30% 0.01 260);
  }

  .toc-list :global(ol) {
    list-style: none;
    padding-left: 1rem;
    counter-reset: toc-h3;
  }

  .toc-list :global(ol > li) {
    counter-increment: toc-h3;
    counter-reset: none;
  }

  .toc-list :global(ol > li > a::before) {
    content: counters(toc-h2, ".") "." counter(toc-h3) ". ";
  }

  /* 引用块：左边框顶到卡片左边缘 */
  :global(#article-content blockquote) {
    margin-left: calc(-1 * var(--card-p, 1.5rem));
    padding-left: calc(var(--card-p, 1.5rem) - 4px);
    border-left-width: 4px;
    border-radius: 0;
  }

  /* 代码块：横跨卡片全宽 */
  :global(#article-content pre) {
    margin-left: calc(-1 * var(--card-p, 1.5rem));
    margin-right: calc(-1 * var(--card-p, 1.5rem));
    padding-left: var(--card-p, 1.5rem);
    padding-right: var(--card-p, 1.5rem);
    border-radius: 0;
  }
</style>
