---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import TableOfContents from "@components/TableOfContents.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

import type { MarkdownHeading } from "astro";
import { TIMEZONE } from "@/settings/consts";

interface Props {
  post: CollectionEntry<"blog">;
  headings: MarkdownHeading[];
  readingTime: number;
}

const { post, headings, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage } = post.data;

const formattedPubDate = pubDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: TIMEZONE,
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: TIMEZONE,
});

// 处理 TOC 层级关系
const toc = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .reduce(
    (acc, heading) => {
      if (heading.depth === 2) {
        acc.push({ ...heading, subHeadings: [] });
      } else if (heading.depth === 3 && acc.length > 0) {
        const lastH2 = acc[acc.length - 1];
        if (lastH2) {
          lastH2.subHeadings.push(heading);
        }
      }
      return acc;
    },
    [] as (MarkdownHeading & { subHeadings: MarkdownHeading[] })[],
  );
---

<BaseLayout
  title={`${title} | PaperAir`}
  description={description}
  image={heroImage?.src}
  type="article"
  mainClass="max-w-7xl"
>
  <div class="blog-layout py-8 lg:py-12">
    <!-- 两栏布局：文章 + TOC -->
    <div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-8">
      <!-- 文章卡片 -->
      <article
        class="card bg-base-100 shadow-sm border border-base-300 min-w-0"
      >
        <!-- 封面图（卡片顶部，无内边距） -->
        {
          heroImage && (
            <figure>
              <Image
                src={heroImage}
                alt={title}
                class="w-full object-cover max-h-80"
                width={800}
                height={320}
              />
            </figure>
          )
        }

        <!-- 卡片内容区 -->
        <div class="card-body">
          <!-- 文章头部信息 -->
          <header class="mb-2">
            <h1
              class="text-3xl sm:text-4xl font-extrabold text-base-content leading-tight"
            >
              {title}
            </h1>
            {
              description && (
                <p class="mt-3 text-lg text-base-content/60">{description}</p>
              )
            }
            <div
              class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-base-content/50"
            >
              <time datetime={pubDate.toISOString()}>
                {formattedPubDate}
              </time>
              {
                formattedUpdatedDate && (
                  <span>(更新于 {formattedUpdatedDate})</span>
                )
              }
              <span class="reading-time">约 {readingTime} 分钟阅读</span>
            </div>
            <div class="divider mt-6 mb-0"></div>
          </header>

          <!-- Markdown 渲染区域 -->
          <div
            class="prose prose-base max-w-none"
            id="article-content"
            data-pagefind-body
          >
            <slot />
            <span data-pagefind-filter="type:blog" class="hidden"></span>
          </div>
        </div>
      </article>

      <!-- 右侧 TOC 卡片 -->
      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <TableOfContents toc={toc} />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  /* 引用块：全宽背景，左边框顶到卡片左边缘 */
  :global(#article-content blockquote) {
    margin-left: calc(-1 * var(--card-p, 1.5rem));
    margin-right: calc(-1 * var(--card-p, 1.5rem));
    padding: 1rem var(--card-p, 1.5rem) 1rem calc(var(--card-p, 1.5rem) - 4px);
    border-left-width: 4px;
    border-radius: 0;
    background-color: var(--color-base-300);
    font-style: normal;
  }

  /* 移除引用块默认的引号 */
  :global(#article-content blockquote p:before),
  :global(#article-content blockquote p:after) {
    content: none !important;
  }

  /* 代码块：横跨卡片全宽 */
  :global(#article-content pre) {
    margin-left: calc(-1 * var(--card-p, 1.5rem));
    margin-right: calc(-1 * var(--card-p, 1.5rem));
    padding-left: var(--card-p, 1.5rem);
    padding-right: var(--card-p, 1.5rem);
    border-radius: 0;
  }
</style>
