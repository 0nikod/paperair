{
  "name": "paperair",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:astro": "astro check",
    "check:biome": "biome check .",
    "check": "pnpm check:astro && pnpm check:biome",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.0",
    "astro": "^5.17.1",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^1.8.5",
    "daisyui": "^5.5.18",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@iconify-json/ri": "^1.2.10",
    "decap-server": "^3.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "**/*.{astro,js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
